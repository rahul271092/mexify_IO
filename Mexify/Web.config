<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  http://go.microsoft.com/fwlink/?LinkId=169433
  -->
<configuration>

  <!-- =========================================
       CONNECTION STRINGS (outside system.web)
       ========================================= -->
  <connectionStrings>
    <add name="MexifyDB"
         connectionString="Server=66.45.231.90;Database=MexifyDB;User Id=mexify_user;Password=Dws@271092;MultipleActiveResultSets=True;Application Name=MexifyApp;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <!-- =========================================
       APP SETTINGS (outside system.web)
       ========================================= -->
  <appSettings>
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
  </appSettings>

  <!-- =========================================
       SYSTEM.WEB (ALL AUTH ELEMENTS INSIDE HERE)
       ========================================= -->
  <system.web>

    <compilation debug="true" targetFramework="4.5.2" />
    <httpRuntime maxRequestLength="10240" executionTimeout="3600" targetFramework="4.5.2" />

    <!-- ✅ FORMS AUTHENTICATION (inside system.web) -->
    <authentication mode="Forms">
      <forms name=".MEXIFYAUTH"
             loginUrl="~/Web/login.aspx"
             defaultUrl="~/User/Dashboard.aspx"
             protection="All"
             timeout="60"
             path="/"
             requireSSL="false"
             slidingExpiration="true"
             cookieSameSite="Lax" />
    </authentication>

    <!-- ✅ AUTHORIZATION (inside system.web) -->
    <authorization>
      <allow users="*" />
    </authorization>

    <!-- ✅ SESSION STATE (inside system.web) -->
    <sessionState mode="InProc"
                  cookieless="false"
                  timeout="60" />

    <!-- ✅ MACHINE KEY (inside system.web) -->
    <machineKey validationKey="A1B2C3D4E5F6A7B8C9D0E1F2A3B4C5D6E7F8A9B0C1D2E3F4A5B6C7D8E9F0A1B2"
                decryptionKey="A1B2C3D4E5F6A7B8C9D0E1F2A3B4C5D6E7F8A9B0C1D2E3F4"
                validation="SHA1"
                decryption="Auto" />

    <!-- ✅ CUSTOM ERRORS -->
    <customErrors mode="Off" />

  </system.web>

  <!-- =========================================
       PROTECT THE USER FOLDER (outside system.web)
       ========================================= -->
  <location path="User">
    <system.web>
      <authorization>
        <deny users="?" />
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <!-- =========================================
       PROTECT THE ADMIN FOLDER (outside system.web)
       ========================================= -->
  <location path="Admin">
    <system.web>
      <authorization>
        <deny users="?" />
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <!-- =========================================
       IIS SERVER SETTINGS (outside system.web)
       ========================================= -->
  <system.webServer>


    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>
    <defaultDocument>
      <files>
        <clear />
        <add value="Web/Default.aspx" />
      </files>
    </defaultDocument>
  </system.webServer>

</configuration>